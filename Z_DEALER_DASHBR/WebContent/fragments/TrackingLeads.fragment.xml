<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout"
	xmlns:layout="sap.ui.layout" xmlns:core="sap.ui.core" xmlns:viz="sap.viz.ui5.controls"
	xmlns:chart="sap.suite.ui.commons" xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
	xmlns:viz.data="sap.viz.ui5.data" xmlns:chartContainer="sap.suite.ui.commons">
	<viz:VizFrame id="idVizFrameTrackingLeadsProvided"
		uiConfig="{applicationSet:'fiori'}" vizType="donut" width="100%"
		height="350px">
		<viz:dataset>
			<viz.data:FlattenedDataset data="{SelectionParameterModel>/Donut}">
				<viz.data:dimensions>
					<viz.data:DimensionDefinition name="Call Types"
						value="{CallType}" />
				</viz.data:dimensions>
				<viz.data:measures>
					<viz.data:MeasureDefinition name="Value"
						value="{Value}" />
				</viz.data:measures>

			</viz.data:FlattenedDataset>
		</viz:dataset>
		<viz:feeds>
			<viz.feeds:FeedItem id='categoryAxisFeedStackedDonut'
				uid="color" type="Dimension" values="Call Types" />
			<viz.feeds:FeedItem id='valueAxisFeedStackedDonut'
				uid="size" type="Measure" values="Value" />

		</viz:feeds>
	</viz:VizFrame>
</core:FragmentDefinition>