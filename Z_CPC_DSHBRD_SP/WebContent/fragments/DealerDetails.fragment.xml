<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" class="sapUiSizeCompact">
	<TableSelectDialog  contentWidth="100%" noDataText="No Data" liveChange="handleDealerDetailsLiveSearch" title="Online Scheduling Leads Details" search="handleDealerDetailsLiveSearch"
		 cancel="handleCloseDealerDetails" multiSelect="false" items="{ path: '/DealerDetails' }">
		<columns>
			<Column width="20%" hAlign="Center" class="columnTitleClass">
				<header>
					<Text text="Customer Name"/>
				</header>
			</Column>
			<Column minScreenWidth="Tablet" hAlign="Center" demandPopin="true" width="16%" class="columnTitleClass">
				<header>
					<Text text="Email"/>
				</header>
			</Column>
			<Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center" width="16%" class="columnTitleClass">
				<header>
					<Text text="Phone"/>
				</header>
			</Column>
			<Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center" width="16%" class="columnTitleClass">
				<header>
					<Text text="Appt. Requested On"/>
				</header>
			</Column>
			<Column hAlign="Center" minScreenWidth="Desktop" width="16%" class="columnTitleClass">
				<header>
					<Text text="Accepted"/>
				</header>
			</Column>
			
			<Column hAlign="Center" minScreenWidth="Desktop" width="16%" class="columnTitleClass">
				<header>
					<Text text="No. of Days Waiting"/>
				</header>
			</Column>
		</columns>
		<items>
			<ColumnListItem vAlign="Middle">
				<cells>
					<Text text="{CustomerName}"/>
					<Text text="{Email}"/>
					<Text text="{Phone}"/>
					<Text text="{ApptRequestedOn}"/>
					<Text text="{Accepted}"/>
					<Text text="{NoOfDaysWaiting}"/> 
				</cells>
			</ColumnListItem>
		</items>
	</TableSelectDialog>
</core:FragmentDefinition>