<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" class="sapUiSizeCompact">
	<l:VerticalLayout>
		<Toolbar style="Clear">
			<Title text="Homeowners Waiting for Dealer Response"
				class="titleSizeClass" />
		</Toolbar>
		<Toolbar style="Clear">
			<l:HorizontalLayout id="leadsAwaitingAction">
				<Label text="{SelectionParameterModel>/LeadsAwaitingAction}"
					class="onlinePercentage
					sapUiTinyMarginEnd" />
					<Text text="Leads Awaiting Action"
						class="leadsAwaitingClass sapUiTinyMarginBegin" />
			</l:HorizontalLayout>
			<ToolbarSpacer />
			<Button tooltip="View Sort Settings" icon="sap-icon://sort"
				press="handleSortButtonPressed" />
		</Toolbar>
		<ScrollContainer vertical="true" width="735px" height="300px"
			horizontal="false">
			<Table width="100%" id="idOnlineSchedulingTable"
				growing="true" growingScrollToLoad="true"
				items="{path:'SelectionParameterModel>/Table'}" class="sapUiTinyMargin">
				<columns>
					<Column width="35%" hAlign="Left" vAlign="Top"
						minScreenWidth="Tablet" demandPopin="true"
						popinDisplay="Inline" mergeDuplicates="false">
						<header>
							<Text text="{i18n>DealerTxt}" width="auto"
								maxLines="2" wrapping="true" textAlign="Begin"
								textDirection="Inherit" />
						</header>
						<footer />
					</Column>
					<Column width="auto" hAlign="Left" vAlign="Top"
						minScreenWidth="Phone" demandPopin="true"
						popinDisplay="Inline" mergeDuplicates="false">
						<header>
							<Text text="{i18n>DealerVHPTxt}" width="auto"
								maxLines="2" wrapping="true" textAlign="Begin"
								textDirection="Inherit" />
						</header>
						<footer />
					</Column>
					<Column width="auto" hAlign="Center" vAlign="Top"
						minScreenWidth="Tablet" demandPopin="true"
						popinDisplay="Inline" mergeDuplicates="false">
						<header>
							<Text text="{i18n>FADTxt}" width="auto"
								maxLines="2" wrapping="true" textAlign="Center"
								textDirection="Inherit" />
						</header>
						<footer />
					</Column>
					<Column width="auto" hAlign="Center" vAlign="Top"
						minScreenWidth="Tablet" demandPopin="true"
						popinDisplay="Inline" mergeDuplicates="false">
						<header>
							<Text text="{i18n>OSSLeads}" width="auto"
								maxLines="2" wrapping="true" textAlign="Center"
								textDirection="Inherit" />
						</header>
						<footer />
					</Column>
					<Column width="auto" hAlign="Center" vAlign="Top"
						minScreenWidth="Tablet" demandPopin="true"
						popinDisplay="Inline" mergeDuplicates="false">
						<header>
							<Text text="{i18n>leadsOfferedTxt}" width="auto"
								maxLines="2" wrapping="true" textAlign="Center"
								textDirection="Inherit" />
						</header>
						<footer />
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Active">
						<cells>
							<Link text="{SelectionParameterModel>Dealer}"
								press="handleDealerLinkPress" wrapping="true" />
							<Text text="{SelectionParameterModel>DealerHVP}"
								textAlign="Center" />
								<Text text="{SelectionParameterModel>FAD}"
									textAlign="Center" />
								<Text text="{SelectionParameterModel>OssLeads}"
									textAlign="Center" />
								<Text text="{SelectionParameterModel>LeadsOffered}"
									textAlign="Center" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</ScrollContainer>
	</l:VerticalLayout>
</core:FragmentDefinition>