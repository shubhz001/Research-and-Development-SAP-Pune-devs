<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:layout="sap.ui.layout" xmlns:core="sap.ui.core"
	xmlns:viz="sap.viz.ui5.controls" xmlns:chart="sap.suite.ui.commons" xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
	xmlns:viz.data="sap.viz.ui5.data">
	
	<viz:VizFrame id="idVizFrameLeadsFactory" uiConfig="{applicationSet:'fiori'}" vizType="column" width="100%" height="350px">
		<viz:dataset>
			<viz.data:FlattenedDataset data="{SelectionParameterModel>/LeadsFactory}">
				<viz.data:dimensions>
					<viz.data:DimensionDefinition name="Month" value="{Month}"/>
				</viz.data:dimensions>
				<viz.data:measures>
					<viz.data:MeasureDefinition name="Call Count" value="{CallCount}"/>
				</viz.data:measures>
			
			</viz.data:FlattenedDataset>
		</viz:dataset>
		<viz:feeds>
			<viz.feeds:FeedItem id='categoryAxisFeedLeadsFactory' uid="categoryAxis" type="Dimension" values="Month"/>
			<viz.feeds:FeedItem id='valueAxisFeedLeadsFactory' uid="valueAxis" type="Measure" values="Call Count"/>
			
		</viz:feeds>
	</viz:VizFrame>
</core:FragmentDefinition>